# ============================================================
# UIG LLC — Environment Variables
# ============================================================
# Copy this file to .env and fill in ALL values before running.
# NEVER commit .env to version control.
#
# Generate SECRET_KEY:          python -c "import secrets; print(secrets.token_hex(32))"
# Generate ADMIN_PASSWORD_HASH: python scripts/hash_password.py

# --- Database ---
DATABASE_URL=postgresql://uig:uigpassword@localhost:5432/uig_pipeline

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Anthropic AI (Claude) ---
ANTHROPIC_API_KEY=

# --- Twilio WhatsApp API ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- SendGrid Email ---
SENDGRID_API_KEY=
OUTREACH_FROM_EMAIL=philip.george@uigllc.org
OUTREACH_FROM_NAME=Philip George

# --- HubSpot CRM ---
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# --- Google Drive (Service Account JSON as single-line string) ---
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# --- Apify (optional — enhanced scraping) ---
APIFY_API_TOKEN=

# --- App ---
SECRET_KEY=                          # REQUIRED — run: python -c "import secrets; print(secrets.token_hex(32))"
ENVIRONMENT=production
ALLOWED_ORIGINS=https://yourdomain.com

# --- Admin credentials ---
ADMIN_EMAIL=admin@uigllc.org
ADMIN_PASSWORD_HASH=                 # REQUIRED — run: python scripts/hash_password.py

# --- Docker Postgres (used by docker-compose) ---
POSTGRES_USER=uig
POSTGRES_PASSWORD=                   # REQUIRED — strong random password
POSTGRES_DB=uig_pipeline

# --- Sender Identity ---
SENDER_NAME=Philip George
SENDER_TITLE=Property Acquisition Manager, Head of Asia Pacific
SENDER_COMPANY=United Investing Group LLC
SENDER_WEBSITE=https://www.uigllc.org


# --- Make.com Automation ---
MAKE_WEBHOOK_URL=
MAKE_FOLLOWUP_SCENARIO_ID=
UIG_INTERNAL_API_KEY=change-me-internal-api-key

# --- n8n Automation Engine ---
N8N_ADMIN_USER=admin
N8N_ADMIN_PASSWORD=                      # REQUIRED — strong random password for n8n admin panel
